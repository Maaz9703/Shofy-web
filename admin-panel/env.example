# Copy to .env for local dev
VITE_API_URL=http://localhost:5000/api

# Vercel (admin and API are different URLs — set this for Production + Preview)
# Project → Settings → Environment Variables → VITE_API_URL
# Example: https://your-backend-name.vercel.app/api
# Redeploy the admin after changing (Vite bakes this in at build time)
