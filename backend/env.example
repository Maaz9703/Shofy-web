# Copy this file to .env and fill in your values
# Server (HOST=0.0.0.0 allows phones on same LAN to reach the API)
PORT=5000
HOST=0.0.0.0
NODE_ENV=development

# Vercel: set MONGODB_URI and JWT_SECRET in Project → Settings → Environment Variables (Production + Preview).
# Do not commit a real .env to git.

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ecommerce

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d

# Stripe (Optional - for online payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
